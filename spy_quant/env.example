# ── Alpaca credentials ─────────────────────────────────────────────────────────
# Paper trading (default safe): https://paper-api.alpaca.markets
# Live trading:                 https://api.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── FRED (macro data) ──────────────────────────────────────────────────────────
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Safety gate ────────────────────────────────────────────────────────────────
# Keep "false" for paper trading. Set "true" ONLY after thorough validation.
LIVE_TRADING_ENABLED=false

# ── Model / training ──────────────────────────────────────────────────────────
# DEVICE: "cuda" for GPU, "cpu" for CPU-only VPS
DEVICE=cpu
BATCH_SIZE=64
EPOCHS=50
# Raised from 3e-4 — warmup prevents this from being too aggressive at init
LEARNING_RATE=0.001
# Fraction of epochs used for linear LR warmup before cosine decay
# 0.10 = 5 warmup epochs on a 50-epoch run, 10 on a 100-epoch run
WARMUP_RATIO=0.10

# Target horizon: how many 5-min bars ahead to predict.
# 1 = original next-bar only (very noisy at 5-min frequency).
# 6 = 30-min forward return, default — ~3x better SNR.
TARGET_HORIZON=6

# ── Risk parameters ────────────────────────────────────────────────────────────
MAX_POSITION_RISK=0.01
STOP_LOSS_PCT=0.005
TAKE_PROFIT_PCT=0.015

# ── Optional: override runtime directories ─────────────────────────────────────
# Leave blank to use defaults (relative to the project root)
DATA_DIR=
CACHE_DIR=
MODEL_DIR=
LOG_DIR=
